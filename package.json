{
  "name": "dk-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check:functions": "tsc -p tsconfig.functions.json --noEmit",
    "auth:migrate:local": "WRANGLER_LOG_PATH=.wrangler/logs npx wrangler d1 migrations apply dk-dashboard-auth --local",
    "auth:migrate:remote": "WRANGLER_LOG_PATH=.wrangler/logs npx wrangler d1 migrations apply dk-dashboard-auth --remote",
    "auth:verify-schema:local": "WRANGLER_LOG_PATH=.wrangler/logs node --import tsx scripts/auth/verify-schema-local.ts",
    "auth:bootstrap-owner": "WRANGLER_LOG_PATH=.wrangler/logs node --import tsx scripts/auth/bootstrap-owner.ts",
    "auth:reset-owner-password": "WRANGLER_LOG_PATH=.wrangler/logs node --import tsx scripts/auth/reset-owner-password.ts",
    "auth:reset-local": "node --import tsx scripts/auth/reset-local.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260228.0",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.0.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.67.0"
  }
}
